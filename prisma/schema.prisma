generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Customer {
  id              String        @id @default(cuid())
  phone           String        @unique
  name            String?
  notes           String?
  lastServiceId   String?
  lastStaffId     String?
  createdAt       DateTime      @default(now())
  appointments    Appointment[]
  lastService     Service?      @relation("CustomerLastService", fields: [lastServiceId], references: [id])
  lastStaff       Staff?        @relation("CustomerLastStaff", fields: [lastStaffId], references: [id])
}

model Service {
  id                   String        @id @default(cuid())
  name                 String
  durationMinutes      Int
  price                Float
  createdAt            DateTime      @default(now())
  appointments         Appointment[]
  customersLastService Customer[]    @relation("CustomerLastService")
}

model Staff {
  id                String        @id @default(cuid())
  name              String
  active            Boolean       @default(true)
  createdAt         DateTime      @default(now())
  appointments      Appointment[]
  customersLastStaff Customer[]   @relation("CustomerLastStaff")
}

model Appointment {
  id                    String   @id @default(cuid())
  customerId            String
  serviceId             String
  staffId               String
  startsAt              DateTime
  status                String   @default("confirmed")
  createdAt             DateTime @default(now())
  reminder24hSentAt     DateTime?
  reminder2hSentAt      DateTime?

  customer              Customer @relation(fields: [customerId], references: [id])
  service               Service  @relation(fields: [serviceId], references: [id])
  staff                 Staff    @relation(fields: [staffId], references: [id])
}

model ConversationState {
  id        String   @id @default(cuid())
  phone     String   @unique
  state     String
  payload   Json?
  updatedAt DateTime @updatedAt
}

model BusinessConfig {
  id                String   @id @default(cuid())
  businessName      String
  welcomeMessage    String?
  address           String?
  phone             String?
  bookingWindowDays Int      @default(30)
  openingHours      Json?
  closedDays        Json?
  bookingSlots      Json?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}